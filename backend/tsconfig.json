{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ES2022"],
		"types": ["@cloudflare/workers-types", "bun"],
		"jsx": "react-jsx",
		"jsxImportSource": "hono/jsx"
	},
	"include": ["src/**/*", "scripts/**/*", "drizzle.config.ts"]
}
